# Divvy Solar Website - Environment Variables
# Copy this file to .env.local and fill in the values

# MongoDB Connection String (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/divvysolar?retryWrites=true&w=majority

# NextAuth - Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_super_secret_key_here_minimum_32_chars

# NextAuth URL - Change for production
NEXTAUTH_URL=http://localhost:3000

# Nodemailer - Gmail credentials
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

# Admin email to receive lead notifications
ADMIN_EMAIL=info@divvysolar.in
